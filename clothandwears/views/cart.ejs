<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cart - Cloth & Wears</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">Cloth & Wears</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="/">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" aria-current="page" href="/cart">Cart</a>
          </li>
          <% if (cart.length > 0) { %>
            <li class="nav-item">
              <a class="nav-link" href="/payment/checkout">Checkout</a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <h1>Your Cart</h1>
    <% if (cart.length) { %>
      <ul class="list-group">
        <% cart.forEach(item => { %>
          <li class="list-group-item">
            Product ID: <%= item.productId %>, Quantity: <%= item.quantity %>, Price: $<%= item.price %>
          </li>
        <% }) %>
      </ul>
      <form action="/payment/checkout" method="POST" class="mt-3">
        <div class="mb-3">
          <label for="phoneNumber" class="form-label">Phone Number for MTN MoMo:</label>
          <input type="text" id="phoneNumber" name="phoneNumber" class="form-control" required>
        </div>
        <button type="submit" class="btn btn-primary">Proceed to Payment</button>
      </form>
    <% } else { %>
      <p>Cart is empty</p>
    <% } %>
    <a href="/" class="btn btn-secondary mt-3">Continue Shopping</a>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r" crossorigin="anonymous"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.min.js" integrity="sha384-0pUGZvbkm6XF6gxjEnlmuGrJXVbNuzT9qBBavbLwCsOGabYfZo0T0to5eqruptLy" crossorigin="anonymous"></script>
</body>
</html>